# === App ===
APP_SECRET_KEY=change-me-32-chars-minimum-random
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# === Supabase ===
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres
SUPABASE_URL=https://[project].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# === Supabase Auth (frontend) ===
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Supabase Auth (backend JWT verification) ===
SUPABASE_JWT_SECRET=

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=changeme

# === PinchTab ===
PINCHTAB_URL=http://localhost:9867
PINCHTAB_TOKEN=your-pinchtab-token-here

# === CORS (comma-separated list of allowed origins, no wildcards) ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# === Internal worker secret (must match INTERNAL_SECRET in worker/.env) ===
INTERNAL_SECRET=change-me-random-secret

# === YouTube Data API (required for interview prep video suggestions) ===
YOUTUBE_API_KEY=

# === Backend ===
BACKEND_URL=http://localhost:8000

# === Resend ===
RESEND_API_KEY=re_...

# === External APIs (optional — users supply their own) ===
# EXA_API_KEY=
